    "lines": [
      {
        "speaker": "A",
        "text": "Good morning!",
        "reading": "",
        "ko": "좋은 아침이에요!",
        "pronun": "구드 모닝!"
      },
      {
        "speaker": "B",
        "text": "Good morning. What a nice day.",
        "reading": "",
        "ko": "좋은 아침이에요. 좋은 날이네요.",
        "pronun": "구드 모닝. 왓 어 나이스 데이."
      },
      {
        "speaker": "A",
        "text": "Yes, the sun is shining.",
        "reading": "",
        "ko": "네, 해가 비추고 있어요.",
        "pronun": "예스, 더 썬 이즈 샤이닝."
      },
      {
        "speaker": "B",
        "text": "I want to go to a cafe.",
        "reading": "",
        "ko": "카페에 가고 싶어요.",
        "pronun": "아이 완트 투 고 투 어 카페."
      },
      {
        "speaker": "A",
        "text": "Me too. Let's get some coffee.",
        "reading": "",
        "ko": "저도요. 커피 좀 마셔요.",
        "pronun": "미 투. 렛츠 겟 썸 커피."
      },
      {
        "speaker": "B",
        "text": "Sounds good. What is the weather like today?",
        "reading": "",
        "ko": "좋아요. 오늘 날씨는 어때요?",
        "pronun": "사운즈 굿. 왓 이즈 더 웨더 라이크 투데이?"
      },
      {
        "speaker": "A",
        "text": "It's warm and sunny.",
        "reading": "",
        "ko": "따뜻하고 화창해요.",
        "pronun": "잇츠 웜 앤 써니."
      },
      {
        "speaker": "B",
        "text": "Perfect for a walk.",
        "reading": "",
        "ko": "산책하기에 완벽하네요.",
        "pronun": "퍼펙트 포 어 워크."
      }
    ]
  }
}